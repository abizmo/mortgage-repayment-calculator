---
type Props = {
  name: string
  url: string
}

const { name, url } = Astro.props
---

<div class="attribution">
  Challenge by <a href="https://www.frontendmentor.io?ref=challenge">
    Frontend Mentor
  </a>. Coded by <a href={url}>{name}</a>.
</div>

<style>
  .attribution {
    font-size: var(--fs-100, 0.6875rem);
    text-align: center;
  }

  .attribution a {
    color: hsl(var(--clr-accent, 228 45% 44%));
    text-decoration: none;
  }
</style>
